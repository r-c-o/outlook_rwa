# Oracle connection for scripts/load_oracle.py (python-oracledb thin mode).
# Copy this file to .env (which is git-ignored) and fill in your values, or
# export these variables in your shell. Never commit real credentials.
#
# Thin mode needs NO Oracle client install — just these four variables.

DB_USER=rwa_user
DB_PASSWORD=change_me
DB_DSN=ora-host:1521/ORCLPDB
DB_SCHEMA=RWA
